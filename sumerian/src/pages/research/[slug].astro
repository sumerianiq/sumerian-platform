---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
export async function getStaticPaths(){ const posts = await getCollection('research'); return posts.map(post => ({ params: { slug: post.slug }, props: { post } })); }
const { post } = Astro.props; const { Content } = await render(post);
---
<BaseLayout title={`${post.data.title} | Sumerian`} description={post.data.summary}><article class="mx-auto max-w-3xl px-5 py-16"><a class="text-accent-cyan" href="/research">← Research</a><h1 class="mt-6 text-4xl font-black">{post.data.title}</h1><p class="mt-3 text-slate-400">{post.data.category} • {post.data.date} • {post.data.readingTime}</p><div class="prose-sumerian mt-10"><Content /></div></article></BaseLayout>
