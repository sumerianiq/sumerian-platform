---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const courses = (await getCollection('courses')).map(c => c.data);
const categories = [...new Set(courses.map(c => c.category))];
---
<BaseLayout title="Courses | Sumerian">
<section class="mx-auto max-w-7xl px-5 py-16">
  <h1 class="text-4xl font-black">Cybersecurity Courses</h1>
  <p class="mt-4 max-w-3xl text-slate-400">Curated free YouTube courses for web security, penetration testing, networking, Linux, SOC, reverse engineering, malware analysis, and AI security.</p>
  <div class="mt-8 grid gap-3 md:grid-cols-[1fr_260px]"><input class="input" id="search" placeholder="Search courses safely..." /><select class="input" id="category"><option value="">All categories</option>{categories.map(c => <option value={c}>{c}</option>)}</select></div>
  <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3" id="courseGrid">
    {courses.map(course => <article class="card course p-5" data-title={course.title.toLowerCase()} data-category={course.category}>
      <div class="mb-4 h-36 rounded-xl bg-gradient-to-br from-accent-cyan/20 to-accent-blue/10"></div>
      <div class="flex flex-wrap gap-2"><span class="badge">{course.category}</span><span class="badge">{course.difficulty}</span><span class="badge">{course.duration}</span></div>
      <h2 class="mt-4 text-xl font-bold">{course.title}</h2><p class="mt-3 text-sm leading-6 text-slate-400">{course.description}</p>
      <a class="mt-5 inline-flex text-accent-cyan" href={course.url} target="_blank" rel="noopener noreferrer">Watch Course →</a>
    </article>)}
  </div>
</section>
<script>
  const search = document.querySelector('#search');
  const category = document.querySelector('#category');
  const cards = Array.from(document.querySelectorAll('.course'));
  const apply = () => {
    const q = String(search.value || '').toLowerCase().slice(0, 80);
    const cat = String(category.value || '');
    cards.forEach((card) => {
      const ok = card.dataset.title.includes(q) && (!cat || card.dataset.category === cat);
      card.toggleAttribute('hidden', !ok);
    });
  };
  search.addEventListener('input', apply);
  category.addEventListener('change', apply);
</script>
</BaseLayout>
