---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
export async function getStaticPaths(){ const posts = await getCollection('cves'); return posts.map(post => ({ params: { slug: post.slug }, props: { post } })); }
const { post } = Astro.props; const { Content } = await render(post);
---
<BaseLayout title={`${post.data.cve} | Sumerian`} description={post.data.summary}><article class="mx-auto max-w-3xl px-5 py-16"><a class="text-accent-cyan" href="/vulnerabilities">← Vulnerabilities</a><div class="mt-6 flex flex-wrap gap-2"><span class="badge">{post.data.cve}</span><span class="badge">{post.data.severity}</span><span class="badge">CVSS {post.data.cvss}</span></div><h1 class="mt-6 text-4xl font-black">{post.data.title}</h1><p class="mt-3 text-slate-400">{post.data.vendor} / {post.data.product} • {post.data.published}</p><div class="prose-sumerian mt-10"><Content /></div><a class="btn-secondary mt-8" href={post.data.source} target="_blank" rel="noopener noreferrer">Read trusted source</a></article></BaseLayout>
